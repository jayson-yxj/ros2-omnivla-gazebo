Panels:
  - Class: rviz_common/Displays
    Name: Displays
Visualization Manager:
  Displays:
    - Class: rviz_default_plugins/Grid
      Enabled: true
      Name: Grid
      Reference Frame: odom
    - Class: rviz_default_plugins/TF
      Enabled: true
      Name: TF
    - Class: rviz_default_plugins/Path
      Enabled: true
      Name: Executed Path
      Topic:
        Value: /vl_nav/omnivla/executed_path
      Color: 25; 255; 0
      Line Width: 0.04
    - Class: rviz_default_plugins/Path
      Enabled: true
      Name: Predicted Path
      Topic:
        Value: /vl_nav/omnivla/predicted_path
      Color: 0; 170; 255
      Line Width: 0.06
    - Class: rviz_default_plugins/Marker
      Enabled: true
      Name: Predicted Path Marker
      Marker Topic:
        Value: /vl_nav/omnivla/predicted_path_marker
    - Class: rviz_default_plugins/Image
      Enabled: true
      Name: Annotated Image
      Topic:
        Value: /vl_nav/omnivla/annotated_image
  Global Options:
    Fixed Frame: odom
    Frame Rate: 30
  Tools:
    - Class: rviz_default_plugins/Interact
    - Class: rviz_default_plugins/MoveCamera
    - Class: rviz_default_plugins/Select
Window Geometry:
  Height: 900
  Width: 1400
