<?xml version="1.0"?>
<sdf version="1.6">
  <model name="stable_diff_cam">
    <pose>0 0 0 0 0 0</pose>

    <link name="base_footprint"/>

    <link name="base_link">
      <pose>0 0 0.045 0 0 0</pose>
      <inertial>
        <pose>0 0 -0.010 0 0 0</pose>
        <mass>2.5</mass>
        <inertia>
          <ixx>0.009</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.016</iyy>
          <iyz>0.0</iyz>
          <izz>0.022</izz>
        </inertia>
      </inertial>
      <collision name="base_collision">
        <geometry>
          <box>
            <size>0.26 0.20 0.06</size>
          </box>
        </geometry>
        <surface>
          <contact>
            <ode>
              <kp>1e+5</kp>
              <kd>1</kd>
              <max_vel>0.01</max_vel>
              <min_depth>0.001</min_depth>
            </ode>
          </contact>
        </surface>
      </collision>
      <visual name="base_visual">
        <geometry>
          <box>
            <size>0.26 0.20 0.06</size>
          </box>
        </geometry>
        <material>
          <ambient>0.05 0.16 0.18 1</ambient>
          <diffuse>0.05 0.38 0.42 1</diffuse>
          <specular>0.02 0.02 0.02 1</specular>
        </material>
      </visual>
      <visual name="camera_mast_visual">
        <pose>0.105 0 0.225 0 0 0</pose>
        <geometry>
          <box>
            <size>0.018 0.018 0.40</size>
          </box>
        </geometry>
        <material>
          <ambient>0.08 0.08 0.08 1</ambient>
          <diffuse>0.08 0.08 0.08 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="base_joint" type="fixed">
      <parent>base_footprint</parent>
      <child>base_link</child>
      <pose>0 0 0.045 0 0 0</pose>
    </joint>

    <link name="wheel_left_link">
      <pose>0 0.120 0.044 -1.5708 0 0</pose>
      <inertial>
        <mass>0.25</mass>
        <inertia>
          <ixx>0.00012</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.00022</iyy>
          <iyz>0.0</iyz>
          <izz>0.00012</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.044</radius>
            <length>0.032</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>4.0</mu>
              <mu2>4.0</mu2>
              <slip1>0.01</slip1>
              <slip2>0.01</slip2>
            </ode>
          </friction>
          <contact>
            <ode>
              <kp>1e+5</kp>
              <kd>1</kd>
              <max_vel>0.01</max_vel>
              <min_depth>0.001</min_depth>
            </ode>
          </contact>
        </surface>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.044</radius>
            <length>0.032</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1</ambient>
          <diffuse>0.02 0.02 0.02 1</diffuse>
        </material>
      </visual>
    </link>

    <link name="wheel_right_link">
      <pose>0 -0.120 0.044 -1.5708 0 0</pose>
      <inertial>
        <mass>0.25</mass>
        <inertia>
          <ixx>0.00012</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.00022</iyy>
          <iyz>0.0</iyz>
          <izz>0.00012</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <cylinder>
            <radius>0.044</radius>
            <length>0.032</length>
          </cylinder>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>4.0</mu>
              <mu2>4.0</mu2>
              <slip1>0.01</slip1>
              <slip2>0.01</slip2>
            </ode>
          </friction>
          <contact>
            <ode>
              <kp>1e+5</kp>
              <kd>1</kd>
              <max_vel>0.01</max_vel>
              <min_depth>0.001</min_depth>
            </ode>
          </contact>
        </surface>
      </collision>
      <visual name="visual">
        <geometry>
          <cylinder>
            <radius>0.044</radius>
            <length>0.032</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1</ambient>
          <diffuse>0.02 0.02 0.02 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="wheel_left_joint" type="revolute">
      <parent>base_link</parent>
      <child>wheel_left_link</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>

    <joint name="wheel_right_joint" type="revolute">
      <parent>base_link</parent>
      <child>wheel_right_link</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>

    <link name="caster_back_link">
      <pose>-0.112 0 0.021 0 0 0</pose>
      <inertial>
        <mass>0.06</mass>
        <inertia>
          <ixx>0.00002</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.00002</iyy>
          <iyz>0.0</iyz>
          <izz>0.00002</izz>
        </inertia>
      </inertial>
      <collision name="collision">
        <geometry>
          <sphere>
            <radius>0.020</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.1</mu>
              <mu2>0.1</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="visual">
        <geometry>
          <sphere>
            <radius>0.020</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.12 0.12 0.12 1</ambient>
          <diffuse>0.12 0.12 0.12 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name="caster_back_joint" type="ball">
      <parent>base_link</parent>
      <child>caster_back_link</child>
    </joint>

    <link name="camera_link">
      <pose>0.125 0 0.500 0 0.13962634 0</pose>
      <inertial>
        <mass>0.06</mass>
        <inertia>
          <ixx>0.00005</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.00005</iyy>
          <iyz>0.0</iyz>
          <izz>0.00005</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry>
          <box>
            <size>0.040 0.052 0.032</size>
          </box>
        </geometry>
        <material>
          <ambient>0.12 0.12 0.12 1</ambient>
          <diffuse>0.12 0.12 0.12 1</diffuse>
        </material>
      </visual>
      <sensor name="camera" type="camera">
        <always_on>true</always_on>
        <visualize>true</visualize>
        <update_rate>20</update_rate>
        <camera>
          <horizontal_fov>2.094395102</horizontal_fov>
          <image>
            <width>320</width>
            <height>240</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.03</near>
            <far>60</far>
          </clip>
        </camera>
        <plugin name="camera_driver" filename="libgazebo_ros_camera.so">
          <camera_name>camera</camera_name>
          <frame_name>camera_link</frame_name>
          <ros>
            <remapping>image_raw:=/camera/image_raw</remapping>
            <remapping>camera_info:=/camera/camera_info</remapping>
          </ros>
        </plugin>
      </sensor>
    </link>

    <joint name="camera_joint" type="fixed">
      <parent>base_link</parent>
      <child>camera_link</child>
      <pose>0.125 0 0.500 0 0.13962634 0</pose>
    </joint>

    <plugin name="stable_diff_drive" filename="libgazebo_ros_diff_drive.so">
      <update_rate>50</update_rate>
      <left_joint>wheel_left_joint</left_joint>
      <right_joint>wheel_right_joint</right_joint>
      <wheel_separation>0.24</wheel_separation>
      <wheel_diameter>0.088</wheel_diameter>
      <max_wheel_torque>12</max_wheel_torque>
      <max_wheel_acceleration>0.45</max_wheel_acceleration>
      <command_topic>cmd_vel</command_topic>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
    </plugin>

    <plugin name="stable_joint_state" filename="libgazebo_ros_joint_state_publisher.so">
      <ros>
        <remapping>~/out:=joint_states</remapping>
      </ros>
      <update_rate>30</update_rate>
      <joint_name>wheel_left_joint</joint_name>
      <joint_name>wheel_right_joint</joint_name>
    </plugin>
  </model>
</sdf>
